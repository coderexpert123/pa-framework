# pa-framework — annotated secrets.env template.
#
# Copy entries you need into ~/.pa/secrets.env. `pa init` scaffolds an
# empty file; this template lists every env var the framework or the
# sample skills consume.
#
# Format: KEY=VALUE pairs, one per line. Lines starting with `#` are
# comments. Surrounding quotes are stripped: VALUE and "VALUE" are
# equivalent.

# ============================================================================
# REQUIRED for most setups
# ============================================================================

# Telegram bot — create one via @BotFather, paste the token here.
TELEGRAM_BOT_TOKEN=

# Telegram destination chat(s) — comma-separated; first entry is the default.
# To find your chat ID:
#   - Private DM: message @userinfobot
#   - Supergroup: add @userinfobot to the group temporarily, or check the
#     URL when viewing the group in web.telegram.org (format -1001234567890)
TELEGRAM_CHAT_ID=

# ============================================================================
# OPTIONAL — bot prompt personalization (Cat B refactors)
# ============================================================================

# Display name the bot uses in its system prompt: "personal assistant for ${PA_USER_NAME}".
# Default: "the user".
# PA_USER_NAME=YourName

# Logs path hint shown to the LLM in the bot's capabilities prompt.
# Default: "~/.pa/logs/<skill>/".
# PA_LOGS_DIR_HINT=~/.pa/logs/<skill>/

# Briefs path hint — only shown to the LLM if set. When set, adds the
# "Today's briefs: <path>/${today}-{morning|evening}.md" capability line.
# PA_BRIEFS_DIR=/path/to/your/obsidian/Mail Briefs

# Bot's default working directory (used by `/code` commands as the fallback).
# Default: process.cwd() at bot startup time.
# BOT_CWD=/absolute/path/to/your/working/project

# Path to your Claude CLI — used by the bot for LLM-based topic description generation.
# Default: "claude" (PATH-resolved).
# CLAUDE_CMD=C:/Users/you/AppData/Roaming/npm/claude.cmd

# Base for /code commands with short folder names (e.g., `/code myrepo` →
# `${PA_REPOS_BASE}/myrepo`). If unset, /code requires absolute paths.
# PA_REPOS_BASE=/home/you/code

# ============================================================================
# OPTIONAL — PA alerts routing (Cat A refactors)
# ============================================================================

# Default destination for `pa notify` alerts (worker failures, rate-limit
# events, evaluator parse failures). Falls back to TELEGRAM_CHAT_ID's first
# entry if unset.
# PA_ALERTS_CHAT_ID=-1001234567890

# Optional forum thread within PA_ALERTS_CHAT_ID. 0 = general.
# PA_ALERTS_THREAD_ID=0

# ============================================================================
# OPTIONAL — framework features (Cat D, J)
# ============================================================================

# Timezone for IST utilities (default 330 = UTC+5:30). E.g., -480 for PST.
# PA_TZ_OFFSET_MINUTES=330

# Gemini daily-quota reset timezone (default America/Los_Angeles).
# PA_GEMINI_RESET_TZ=America/Los_Angeles

# Cloned framework root — used by example skills via ${PA_FRAMEWORK_ROOT}
# interpolation in cwd/cmd fields. Set this to the absolute path of your
# pa-framework clone.
# PA_FRAMEWORK_ROOT=/home/you/pa-framework

# ============================================================================
# OPTIONAL — Python helpers (Cat E)
# ============================================================================

# Profile path for pa/src/{learn,oracle,travel_butler}_agent.py
# Default: ~/.pa/data/profile.json
# PA_PROFILE_PATH=~/.pa/data/profile.json

# Google Drive folder ID for upload_plan.py (deep-plan skill workflow).
# Create a folder, copy the ID from the URL (after /folders/).
# PA_PLANS_DRIVE_FOLDER_ID=

# Public HTTPS URL where projects/google-oauth-redirect/ is deployed.
# The URL must exactly match an authorized redirect URI on your Google OAuth
# Web application client.
# GOOGLE_AUTH_REDIRECT_URI=https://your-domain.example.com/google-oauth-redirect/

# Optional hook the bot runs after /auth succeeds. If unset, the bot also checks
# for ~/.pa/oauth_resume_hook.py automatically.
# PA_TELEGRAM_OAUTH_RESUME_HOOK=~/.pa/oauth_resume_hook.py

# Optional path overrides for the Telegram/mobile Google OAuth flow.
# GOOGLE_TELEGRAM_CREDENTIALS_FILE=~/.pa/google-credentials-telegram.json
# GOOGLE_TELEGRAM_TOKEN_FILE=~/.pa/google-token.json
# GOOGLE_TELEGRAM_STATE_FILE=~/.pa/google-telegram-auth.json

# ============================================================================
# OPTIONAL — daily-mail-brief sample (Cat F)
# ============================================================================

# Path to your gemini CLI binary. If you use a shim/wrapper, point here.
# Default: "gemini" (PATH-resolved).
# GEMINI_CMD=/usr/local/bin/gemini

# Obsidian destination for archived briefings. If unset, archival is
# skipped silently — the briefing still goes to Telegram.
# OBSIDIAN_BRIEFS_DIR=/path/to/your/obsidian/Mail Briefs

# Briefing-specific Telegram destination (defaults to TELEGRAM_CHAT_ID's
# first entry if unset).
# TELEGRAM_BRIEFING_CHAT_ID=-1001234567890

# Forum thread within TELEGRAM_BRIEFING_CHAT_ID where briefings post.
# TELEGRAM_DAILY_BRIEFING_THREAD_ID=29

# ============================================================================
# OPTIONAL — third-party API credentials (used by domain projects you build)
# ============================================================================

# Strava (if you build a Strava-integration skill)
# STRAVA_CLIENT_ID=
# STRAVA_CLIENT_SECRET=
# STRAVA_REFRESH_TOKEN=

# Coros (if you build a Coros-integration skill)
# COROS_EMAIL=
# COROS_PASSWORD=

# ============================================================================
# Claude Code on Windows — needs explicit git bash path
# ============================================================================

# CLAUDE_CODE_GIT_BASH_PATH=C:/Program Files/Git/bin/bash.exe
