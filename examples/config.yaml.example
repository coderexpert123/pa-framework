# pa-framework — annotated config template.
#
# Copy this to ~/.pa/config.yaml after `pa init` and customize for your setup.
# `pa init` scaffolds a minimal default; this template shows ALL fields.

workers:
  # ---- zclaude (priority 1 — your highest-preferred worker) ----
  - name: zclaude
    command: zclaude          # PATH-resolved binary, or absolute path
    # Windows: command: C:/Users/you/.local/bin/zclaude.bat
    # POSIX:   command: ~/.local/bin/zclaude
    args:
      - "-p"
      - "--dangerously-skip-permissions"
      - "--output-format"
      - "stream-json"
      - "--input-format"
      - "stream-json"
      - "--verbose"
    input_mode: stdin-json
    output_format: stream-json
    check: zclaude --version
    check_timeout: 30           # seconds; default 30
    rate_limit_patterns:
      - "rate limit"
      - "token limit"
      - "quota exceeded"
      - "Usage limit"
      - "over your limit"
      - "hit your limit"
      - "429"
    priority: 1
    state_dir: "~/.claude/projects"   # for session-mode rate-limit detection
    state_pattern: "*.jsonl"
    # ---- tunables (optional) ----
    # User-settable knobs this worker's CLI exposes. The bot surfaces them as
    # ONE uniform command per knob (/llm <name>, /effort <value>) regardless of
    # which CLI is active; everything CLI-specific lives here.
    #
    #   args:        REQUIRED. An ARG TEMPLATE, not a flag+value pair — every
    #                "{value}" is substituted and the whole template is appended
    #                to this worker's args, but ONLY when the setting is set.
    #                A template array is what lets a CLI express the same knob
    #                as a config override: ["-c", "model_reasoning_effort={value}"].
    #   default:     optional worker-level default. OMIT to pass nothing at all
    #                and leave the CLI's own default in charge.
    #   values:      optional DISPLAY HINT — a list, or a canonical->native map
    #                ({low: "1", high: "3"}) when the CLI's vocabulary differs
    #                from the bot-level word. NEVER an allowlist: a value that is
    #                not listed is still passed through (model names change far
    #                faster than this file). Declare it only where the CLI itself
    #                documents a closed vocabulary.
    #   description: optional help text, shown by the bot and the dashboard.
    #   supersedes:  optional list of OTHER setting names this one suppresses.
    #                When this setting has a value, each named setting emits no
    #                args, even if the user set it. For the CLIs that reject a
    #                combination outright (see agy below), emitting both would
    #                fail EVERY dispatch to the worker. The suppressed setting
    #                keeps its value and the bot reports that it was superseded,
    #                so clearing this one brings it straight back.
    #
    # ONLY DECLARE FLAGS THE CLI ACTUALLY HAS. A flag a CLI does not accept
    # fails EVERY dispatch to that worker and reads as an outage, not a config
    # error — verify against the CLI's own --help. Under-declaring is safe: a
    # worker with no tunables block simply has no settable knobs.
    tunables:
      model:
        args: ["--model", "{value}"]
        description: "Model name passed to the CLI (e.g. opusplan, opus, sonnet)."
      effort:
        args: ["--effort", "{value}"]
        values: [low, medium, high, xhigh, max]
        description: "Effort level for the session (Claude Code 2.x --effort)."

  # ---- gemini (priority 3 — fallback below agy) ----
  - name: gemini
    command: gemini
    # Tip: point command at a small wrapper script if your CLI needs env vars
    # set or arg-quoting fixes (see docs/WORKERS_GUIDE.md). worker-exec spawns
    # this command verbatim — no name-based rewriting.
    args:
      - "--yolo"
      - "--output-format"
      - "stream-json"
    input_mode: stdin-text
    output_format: stream-json
    check: gemini --version
    check_timeout: 10
    rate_limit_patterns:
      - "RESOURCE_EXHAUSTED"
      - "429"
      - "quota"
      - "rate limit"
      - "Resource exhausted"
    priority: 3
    state_dir: "~/.gemini/tmp/personal-assistant/chats"  # must match GEMINI_PROJECT_DIR
    state_pattern: "*.jsonl"   # gemini-cli writes session-<ts>-<id>.jsonl (verified 2026-07-22)
    # gemini-cli has -m/--model and NO reasoning-effort flag, so no effort knob
    # here — the bot uses that absence to explain why /effort is unavailable.
    tunables:
      model:
        args: ["--model", "{value}"]
        description: "Model name (e.g. gemini-2.5-pro)."

  # ---- codex (priority 4) ----
  - name: codex
    command: codex
    # Windows (Node-based, path varies by npm setup):
    # command: node C:/Users/<you>/AppData/Roaming/npm/node_modules/@openai/codex/bin/codex.js
    # POSIX:   command: codex   (or: node ~/.npm-global/lib/node_modules/@openai/codex/bin/codex.js)
    args:
      - "exec"
      - "--dangerously-bypass-approvals-and-sandbox"
      - "--color"
      - "never"
      - "--json"
      - "-"
    input_mode: stdin-text
    output_format: stream-json
    check: codex --version
    check_timeout: 15
    rate_limit_patterns:
      - "hit your usage limit"
      - "rate limit"
      - "quota exceeded"
      - "429"
    priority: 4
    state_dir: "~/.codex"
    state_pattern: "state_5.sqlite"   # SQLite; same caveat as agy — heartbeat, not transcript, drives stuck-detection
    # codex has no --effort flag; reasoning effort is a -c config override —
    # which is exactly why "args" is a template array and not flag+value.
    tunables:
      model:
        args: ["--model", "{value}"]
        description: "Model the agent should use."
      effort:
        args: ["-c", "model_reasoning_effort={value}"]
        values: [minimal, low, medium, high]
        description: "Reasoning effort, via codex's -c config override."

  # ---- claude (priority 5 — last resort) ----
  - name: claude
    command: claude
    # Windows: command: C:/Users/<you>/AppData/Roaming/npm/claude.cmd
    # POSIX:   command: claude   (if in PATH) or ~/.local/bin/claude
    args:
      - "-p"
      - "--dangerously-skip-permissions"
      - "--output-format"
      - "stream-json"
      - "--input-format"
      - "stream-json"
      - "--verbose"
    input_mode: stdin-json
    output_format: stream-json
    check: claude --version
    rate_limit_patterns:
      - "rate limit"
      - "token limit"
      - "quota exceeded"
      - "Usage limit"
      - "over your limit"
      - "hit your limit"
    priority: 5
    state_dir: "~/.claude/projects"
    state_pattern: "*.jsonl"
    tunables:
      model:
        args: ["--model", "{value}"]
        description: "Model name passed to the CLI (e.g. opusplan, opus, sonnet)."
      effort:
        args: ["--effort", "{value}"]
        values: [low, medium, high, xhigh, max]
        description: "Effort level for the session (Claude Code 2.x --effort)."

  # ---- agy (priority 2 — Antigravity CLI) ----
  # Plain-text worker: it has no --output-format flag, so pa never sees
  # stream-json events from it. Consequence: pa cannot capture a native session
  # id for agy (worker-exec only reads session ids off stream-json events), so
  # conversation continuity must come from prompt-injected history, not from
  # resuming a native session.
  - name: agy
    command: agy
    # Tip: point command at a small wrapper script if your CLI needs env vars
    # set (e.g. GCP project vars, token refresh) or arg-quoting fixes (see
    # docs/WORKERS_GUIDE.md). worker-exec spawns this command verbatim — no
    # name-based rewriting.
    args:
      - "--dangerously-skip-permissions"
      # Required: agy's print mode self-kills at 5m0s by default, which is far
      # below any real synthesis run. 65m sits just ABOVE pa's own
      # DEFAULT_TIMEOUT (3600s) so pa's max-timeout is always the layer that
      # fires — pa logs an attributable "exceeded max timeout" and feeds failure
      # backoff, whereas an agy-side kill surfaces only as an opaque non-zero
      # exit. If a skill sets `timeout:` above 3600, raise this too.
      - "--print-timeout"
      - "65m"
      # {prompt} is NOT inlined on the command line: worker-exec.ts (arg mode)
      # writes the prompt to a temp file and substitutes '@<path>', which agy
      # resolves client-side. So prompt size is not capped by the shell.
      - "-p"
      - "{prompt}"
    input_mode: arg           # prompt passed as a CLI arg, not over stdin
    output_format: plain-text # agy has no --output-format flag; do not claim stream-json
    check: agy --version
    check_timeout: 10
    rate_limit_patterns:
      - "RESOURCE_EXHAUSTED"
      - "429"
    priority: 2
    state_dir: "~/.gemini/antigravity-cli/conversations"
    # Each conversation is a SQLite database in WAL mode, hence the sibling
    # <id>.db-shm / <id>.db-wal files ('*.db' matches on suffix, so those are
    # excluded). pa's state reader is line-oriented JSON and cannot parse
    # SQLite — it reports "unknown" instead of guessing, so agy stuck-detection
    # relies on the process-tree heartbeat rather than transcript inspection.
    state_pattern: "*.db"
    # THE `supersedes:` CASE. On agy (v1.1.5, every line below is a real
    # invocation from 2026-07-22) model and effort are NOT independent knobs:
    #   --model gemini-3.6-flash                  -> ERROR: invalid model selection ... --effort ""
    #   --model gemini-3.6-flash --effort high    -> OK
    #   --model gemini-3.6-flash-high             -> OK   (the suffix IS the effort)
    #   --model claude-sonnet-4-6 --effort high   -> ERROR: --effort is not supported
    #   --effort high  (no model)                 -> OK
    # `agy models` lists no bare gemini names — every gemini entry carries an
    # effort suffix, and the Claude/GPT entries reject --effort. So the model
    # alone is correct for every name agy offers, and "both" is wrong for half
    # of them. Without the rule below, a user who set both would break EVERY
    # dispatch in their topic and see it as a worker outage.
    tunables:
      model:
        args: ["--model", "{value}"]
        supersedes: [effort]
        # Declared here (unusually for a model knob) precisely because the
        # effort suffix makes the vocabulary worth showing. Still a hint: an
        # unlisted id passes through, so a model that ships tomorrow works.
        values: ["gemini-3.6-flash-high", "gemini-3.6-flash-medium", "gemini-3.6-flash-low", "gemini-3.5-flash-high", "gemini-3.5-flash-medium", "gemini-3.5-flash-low", "gemini-3.1-pro-high", "gemini-3.1-pro-low", "claude-sonnet-4-6", "claude-opus-4-6-thinking", "gpt-oss-120b-medium"]
        description: "Model for this CLI session (run `agy models` for the current list — from PowerShell/cmd, not Git Bash, where it hangs). Effort is embedded in the gemini names; a base name with no -high/-medium/-low suffix is rejected."
      effort:
        args: ["--effort", "{value}"]
        values: [low, medium, high]
        description: "Reasoning effort when no model is set (agy's own default is low). Superseded once a model is set."

# ---- evaluator (optional) ----
# When a worker appears stuck (no output for idle_timeout seconds), the
# orchestrator consults this LLM to decide: extend timeout, kill, or
# fail-over to next worker.
evaluator:
  worker: claude            # name must match one of the workers above
  timeout: 60               # seconds; default 60

# ---- topic_defaults (optional) ----
# Maps Telegram (chat_id, thread_id) pairs to a preferred worker.
# Useful when you want different topics to default to different LLMs
# (e.g., a "coding" topic always uses claude, a "research" topic always
# uses gemini). The bot's /model command can override per-topic; this
# is the initial default.
topic_defaults:
  # "1000000001_0": zclaude            # private chat with this user_id, topic 0 → zclaude
  # "-1001234567890_310": claude       # supergroup thread 310 → claude
  # "-1001234567890_29": gemini

# ---- bg_tasks (background-leak detection) ----
bg_tasks:
  alert_seconds: 300          # alert if a worker's descendant outlives parent by N seconds; min 60
  alert_repeat_seconds: 1800  # repeat alerts every N seconds (must be >= alert_seconds); default 1800
