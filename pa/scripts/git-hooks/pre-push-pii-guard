#!/usr/bin/env python3
"""
pre-push PII guard for the public pa-framework mirror.

Strategy (layers, fastest-first). Every regex layer scans PATHS as well as
contents — the 2026-07-21 leak shipped a bank's name in a FILENAME
(download_exbank_statement.py) whose contents were entirely generic, and passed
every content-only layer.

  0. Path + commit-message tripwire regex — the file NAMES a push ships
     (post-rename NEW path) and the messages it publishes. Both are content
     GitHub serves and neither was ever scanned before 2026-07-21.
  1. Structural regex — catches unambiguous credentials immediately (no LLM).
  2. Personal tripwire regex — patterns from ~/.pa/pii-tripwires.txt (outside repo).
  3. Gemini semantic scan — catches personal data that doesn't match a regex.

SCOPE, per layer (this asymmetry is deliberate — say it out loud in the output
so nobody re-learns it the hard way):
  * Layers 0-2 (regex, free) scan the FULL resulting content of every file the
    push touches, plus the added lines, plus every touched path, plus every
    commit message. Scanning only the '+' lines of a diff — what this hook did
    until 2026-07-21 — makes PII that was already committed permanently
    invisible, which is how three separate leaks survived every push for months.
  * Layer 3 (Gemini, metered) stays ADDED-LINES ONLY, for budget. It is not a
    full-content scan and must never be described as one. The weekly `--full`
    audit is what gives the semantic layer whole-tree coverage.

Fail-open on LLM errors: a Gemini timeout or missing binary produces a LOUD
banner but does NOT block the push. Regex layers always run.

Set PA_SKIP_PII_GUARD=1 to bypass entirely — printed as a banner AND appended
to ~/.pa/pii-guard-bypass.jsonl, so a bypass is never invisible after the fact.

Modes:
  (default)      pre-push hook — scans the outgoing push (see SCOPE above).
  --full         audit mode — scans EVERY tracked path + file of the repo the
                 GIT_DIR env var points at (default: .git-public relative to
                 cwd). Reports all violations. Use for the scheduled pii-audit
                 skill / manual full-tree sweeps.
  --no-llm       with --full: skip the Gemini layer (regex + tripwires only).

Install:
  cp pa/scripts/git-hooks/pre-push-pii-guard .git-public/hooks/pre-push
  chmod +x .git-public/hooks/pre-push
"""
import json
import os
import re
import shutil
import subprocess
import sys
import time
from concurrent.futures import ThreadPoolExecutor
from datetime import datetime, timezone

# Windows consoles may be cp1252 — the emoji status output must never crash the guard.
for _stream in (sys.stdout, sys.stderr):
    try:
        _stream.reconfigure(encoding="utf-8", errors="replace")
    except Exception:
        pass

PA_HOME = os.environ.get("PA_HOME") or os.path.join(os.path.expanduser("~"), ".pa")

# AI-097: git hooks run with a minimal inherited environment — GEMINI_CMD
# lives in ~/.pa/secrets.env but is not exported into that environment
# unless something explicitly does so. Same self-contained-script pattern as
# projects/coding-dirs-updater/update_coding_dirs.py's _load_secrets().
def _load_secrets() -> dict[str, str]:
    path = os.path.join(PA_HOME, "secrets.env")
    out: dict[str, str] = {}
    try:
        with open(path, encoding="utf-8") as f:
            for line in f:
                line = line.strip()
                if not line or line.startswith("#") or "=" not in line:
                    continue
                key, _, val = line.partition("=")
                out[key.strip()] = val.strip().strip("\"'")
    except FileNotFoundError:
        pass
    return out

# Structural credential patterns — always block, no LLM needed.
CREDENTIAL_PATTERNS = [
    r"[0-9]{8,10}:[A-Za-z0-9_\-]{35}",    # Telegram bot token
    r"sk-ant-[A-Za-z0-9_\-]{20,}",          # Anthropic API key
    r"sk-proj-[A-Za-z0-9_\-]{20,}",         # OpenAI project key
    r"AIza[0-9A-Za-z_\-]{35}",              # Google API key
    r"BOT_TOKEN\s*=\s*[\"'][0-9]{6,}",      # Hardcoded bot token assignment
    r"CHAT_ID\s*=\s*[\"']-?[0-9]{7,}",      # Hardcoded chat ID assignment
]

EMPTY_TREE = "4b825dc642cb6eb9a060e54bf8d69288fbee4904"

# Added lines from this push (content only, no leading +).
ADDED: list[str] = []
# Every path the push ships (post-rename NEW path; deletions excluded).
TOUCHED_PATHS: list[str] = []
# (path, FULL content at the pushed tip) for every touched text file we could
# read. Not the diff — the whole file, so pre-existing PII in a touched file
# is caught instead of being permanently invisible.
TOUCHED_FILES: list[tuple[str, str]] = []
# Touched paths whose content could not be read (binary/oversized/error).
UNREADABLE_PATHS: list[str] = []
# (sha, message) for every commit the push introduces.
MESSAGES: list[tuple[str, str]] = []

# A brand-new branch push has no remote base, so the whole history is "new".
MAX_SCANNED_COMMITS = 1000
# git log record/field separators — ASCII RS/US, which cannot occur in a message.
_REC, _FLD = "\x1e", "\x1f"

# Content-scan budget for a single push. Path scanning is unbounded (it is a
# regex over a string). 500 `git show` calls across 8 threads is ~2-4s.
MAX_TOUCHED_FILES = 500
BLOB_READ_WORKERS = 8


def warn_layer_skipped(layer: str, why: str, stream=None) -> None:
    """Unmissable fail-open banner. Silence is the failure mode this whole
    module exists to prevent: a layer that quietly does not run looks exactly
    like a layer that ran and found nothing."""
    out = stream if stream is not None else sys.stderr
    bar = "!" * 74
    for line in (
        bar,
        f"!! PII GUARD FAIL-OPEN — layer did NOT run: {layer}",
        f"!! Why: {why}",
        "!! This content was NOT checked by that layer. Proceeding by design",
        "!! (an infra failure must never wedge a push), but do not read the",
        "!! absence of findings as a clean verdict. Re-check manually with:",
        "!!   python pa/scripts/git-hooks/pre-push-pii-guard --full",
        bar,
    ):
        print(line, file=out, flush=True)


def _read_push_refs() -> list[str]:
    """Consume the pre-push stdin protocol into human-readable ref lines."""
    refs: list[str] = []
    try:
        for line in sys.stdin:
            line = line.strip()
            if not line:
                continue
            parts = line.split()
            if len(parts) >= 4:
                refs.append(f"{parts[0]} {parts[1][:12]} -> {parts[2]} {parts[3][:12]}")
            else:
                refs.append(line)
    except Exception:
        pass
    return refs


def record_bypass(refs: list[str]) -> str | None:
    """Append a durable record of a PA_SKIP_PII_GUARD bypass to ~/.pa/.

    Deliberately OUTSIDE the repo: the record must not itself become something
    that has to be reviewed before a public push. Returns the log path on
    success, None on failure (never raises — a bookkeeping failure must not
    block the push the user already chose to force through)."""
    path = os.path.join(PA_HOME, "pii-guard-bypass.jsonl")
    entry = {
        "ts": datetime.now(timezone.utc).isoformat(timespec="seconds"),
        "event": "pii-guard-bypass",
        "env_var": "PA_SKIP_PII_GUARD",
        "refs": refs,
        "cwd": os.getcwd(),
        "git_dir": os.environ.get("GIT_DIR", ""),
        # git passes the remote name + URL as argv to a pre-push hook.
        "remote": sys.argv[1] if len(sys.argv) > 1 else "",
        "remote_url": sys.argv[2] if len(sys.argv) > 2 else "",
    }
    try:
        os.makedirs(PA_HOME, exist_ok=True)
        with open(path, "a", encoding="utf-8") as f:
            f.write(json.dumps(entry) + "\n")
        return path
    except Exception as exc:
        print(f"⚠  PII guard: could not record bypass to {path} ({exc})", file=sys.stderr)
        return None


def collect_diff():
    """Read push info from stdin; populate ADDED (new content lines),
    TOUCHED_PATHS (names the push ships) and TOUCHED_FILES (full content)."""
    for line in sys.stdin:
        parts = line.strip().split()
        if len(parts) < 4:
            continue
        local_sha, remote_sha = parts[1], parts[3]
        if local_sha == "0" * 40:
            continue  # branch deletion
        base = EMPTY_TREE if remote_sha == "0" * 40 else remote_sha
        _collect_added(base, local_sha)
        _collect_touched(base, local_sha)
        _collect_messages(remote_sha, local_sha)


def _collect_added(base: str, local_sha: str) -> None:
    try:
        # encoding="utf-8", errors="replace" is load-bearing (same AI-097
        # class as gemini_check below): without it, Windows decodes the diff
        # with the system codepage (cp1252), which silently mojibakes
        # em-dashes and HARD-CRASHES on the undefined byte 0x8f in a ⚠️
        # variation selector (EF B8 8F). Caught by the except below, that
        # crash empties ADDED → the whole per-push scan silently vets nothing
        # and the push proceeds unchecked (observed 2026-07-12).
        result = subprocess.run(
            ["git", "diff", "--unified=0", base, local_sha],
            capture_output=True, text=True, encoding="utf-8", errors="replace",
            timeout=30,
        )
        for dl in result.stdout.splitlines():
            if dl.startswith("+") and not dl.startswith("+++"):
                ADDED.append(dl[1:])
    except Exception as e:
        # Fail-open (never wedge a push on a git hiccup) but LOUD — a silent
        # empty-ADDED here means the guard vetted nothing, the exact
        # silent-failure class this hook exists to prevent.
        print(f"⚠  PII guard: could not diff {base[:12]}..{local_sha[:12]} "
              f"({e}); this ref's added lines were NOT scanned", file=sys.stderr)


def _collect_touched(base: str, local_sha: str) -> None:
    """Name-status the push and read the FULL content of what it ships.

    Two gaps closed here, both of which shipped real PII in 2026-07:
      * the diff only shows ADDED lines, so PII already committed in a file the
        push touches is never re-examined;
      * nothing ever looked at the file NAMES — a rename INTO a bad path adds
        zero lines and therefore produced an entirely empty diff scan.
    --find-renames + parts[-1] means the NEW path is what gets checked;
    --diff-filter excludes D, because a deleted path is not shipped.
    """
    try:
        result = subprocess.run(
            ["git", "-c", "core.quotepath=false", "diff", "--name-status",
             "--find-renames", "--diff-filter=ACMRT", base, local_sha],
            capture_output=True, text=True, encoding="utf-8", errors="replace",
            timeout=30,
        )
    except Exception as e:
        warn_layer_skipped(
            "path + full-content regex scan",
            f"could not name-status {base[:12]}..{local_sha[:12]} ({e}) — "
            f"only this ref's ADDED lines were scanned",
        )
        return

    paths: list[str] = []
    for dl in result.stdout.splitlines():
        fields = [f for f in dl.split("\t") if f.strip()]
        if len(fields) < 2:
            continue
        path = fields[-1].strip()  # rename/copy → NEW path
        if path and path not in TOUCHED_PATHS:
            TOUCHED_PATHS.append(path)
            paths.append(path)

    readable = [p for p in paths if not p.lower().endswith(SKIP_EXTENSIONS)]
    if len(readable) > MAX_TOUCHED_FILES:
        print(f"⚠  PII guard: {len(readable)} touched files exceeds the "
              f"{MAX_TOUCHED_FILES}-file full-content budget — the remainder "
              f"were PATH-scanned and added-line-scanned only", file=sys.stderr)
        skipped = readable[MAX_TOUCHED_FILES:]
        UNREADABLE_PATHS.extend(skipped)
        readable = readable[:MAX_TOUCHED_FILES]

    for path, content in _read_blobs(local_sha, readable):
        if content is None:
            UNREADABLE_PATHS.append(path)
        else:
            TOUCHED_FILES.append((path, content))


def _parse_log_records(stdout: str) -> list[tuple[str, str]]:
    out: list[tuple[str, str]] = []
    for record in stdout.split(_REC):
        if _FLD not in record:
            continue
        sha, _, body = record.partition(_FLD)
        sha = sha.strip()
        if sha:
            out.append((sha, body))
    return out


def _collect_messages(remote_sha: str, local_sha: str) -> None:
    """Scan the COMMIT MESSAGES the push introduces.

    A third unscanned channel, proven live on 2026-07-21: the very commit that
    renamed the bank-named file away carried that filename in its own subject
    line, so `git log` on the public mirror still published the term the rename
    was removing. Diffs, file contents and paths were all clean; the message
    was not, and nothing had ever looked at one."""
    rng = local_sha if remote_sha == "0" * 40 else f"{remote_sha}..{local_sha}"
    try:
        result = subprocess.run(
            ["git", "log", f"--format={_FLD.join(['%H', '%B'])}{_REC}",
             f"--max-count={MAX_SCANNED_COMMITS}", rng],
            capture_output=True, text=True, encoding="utf-8", errors="replace",
            timeout=30,
        )
    except Exception as e:
        warn_layer_skipped(
            "commit-message regex scan",
            f"could not read the log for {rng} ({e})",
        )
        return
    if result.returncode != 0:
        warn_layer_skipped(
            "commit-message regex scan",
            f"git log {rng} failed: {result.stderr.strip()[:200]}",
        )
        return
    MESSAGES.extend(_parse_log_records(result.stdout))


def list_commit_messages(git_dir: str) -> list[tuple[str, str]]:
    """Every commit message in the audited repo's history — the --full-mode
    counterpart to _collect_messages."""
    try:
        result = subprocess.run(
            ["git", "--git-dir", git_dir, "--work-tree", ".", "log", "--all",
             f"--format={_FLD.join(['%H', '%B'])}{_REC}",
             f"--max-count={MAX_SCANNED_COMMITS}"],
            capture_output=True, text=True, encoding="utf-8", errors="replace",
            timeout=60,
        )
    except Exception as e:
        warn_layer_skipped("commit-message regex scan",
                           f"could not read the log ({e})", stream=sys.stdout)
        return []
    return _parse_log_records(result.stdout)


def scan_messages(messages: list[tuple[str, str]], tripwires: list[str]) -> list[str]:
    """Regex layers against commit messages, marked `[COMMIT MSG]` so it is
    obvious the fix is a history rewrite, not a file edit."""
    violations: list[str] = []
    for sha, body in messages:
        violations.extend(scan_text(f"[COMMIT MSG] {sha[:12]}", body, tripwires))
    return violations


def _read_blob(local_sha: str, path: str) -> tuple[str, str | None]:
    try:
        result = subprocess.run(
            ["git", "show", f"{local_sha}:{path}"],
            capture_output=True, text=True, encoding="utf-8", errors="replace",
            timeout=30,
        )
    except Exception:
        return path, None
    if result.returncode != 0:
        return path, None
    if len(result.stdout) > FULL_SCAN_MAX_BYTES:
        return path, None
    return path, result.stdout


def _read_blobs(local_sha: str, paths: list[str]) -> list[tuple[str, str | None]]:
    """Fetch blob contents concurrently — these are I/O-bound subprocess calls,
    and a 200-file push must still finish in seconds."""
    if not paths:
        return []
    workers = min(BLOB_READ_WORKERS, len(paths))
    with ThreadPoolExecutor(max_workers=workers) as pool:
        return list(pool.map(lambda p: _read_blob(local_sha, p), paths))


def load_tripwires() -> list[str]:
    """Load personal PII regexes from ~/.pa/pii-tripwires.txt."""
    path = os.path.join(PA_HOME, "pii-tripwires.txt")
    try:
        with open(path, encoding="utf-8") as f:
            return [ln.strip() for ln in f if ln.strip() and not ln.startswith("#")]
    except FileNotFoundError:
        return []


def resolve_gemini_argv() -> list[str] | None:
    """
    Resolve the Gemini invocation, Windows-aware.

    Order: $GEMINI_CMD, then `gemini` on PATH. Returns the argv prefix (before
    flags) or None when nothing resolvable — the caller fail-opens with a
    warning either way, but None makes the "layer silently off" state explicit.

    Windows: a `.cmd`/`.bat` shim cannot be exec'd directly by subprocess with
    a list argv — it needs the cmd.exe interpreter. This was the bug that kept
    the semantic layer silently disabled (AI-094).
    """
    candidate = (
        os.environ.get("GEMINI_CMD")
        or shutil.which("gemini")
        or _load_secrets().get("GEMINI_CMD")
    )
    if not candidate:
        return None
    if candidate.lower().endswith((".cmd", ".bat")):
        return ["cmd", "/c", candidate]
    return [candidate]


GEMINI_TIMEOUT = 120  # seconds per call (healthy shim answers in ~40s)


def _kill_process_tree(proc: subprocess.Popen) -> None:
    """Kill proc and every descendant. On Windows the resolved Gemini argv is
    `cmd /c shim.cmd` — killing only the direct child (cmd.exe) orphans the
    node grandchild, which busy-spins at 100% CPU forever with its stdin pipe
    broken (observed 2026-07-20: six orphans burning six cores, leaked one per
    timed-out audit chunk)."""
    if os.name == "nt":
        subprocess.run(
            ["taskkill", "/F", "/T", "/PID", str(proc.pid)],
            capture_output=True, timeout=30,
        )
    else:
        import signal
        try:
            os.killpg(os.getpgid(proc.pid), signal.SIGKILL)
        except (ProcessLookupError, PermissionError, OSError):
            proc.kill()


def _run_gemini(argv: list[str], prompt: str, timeout: float) -> subprocess.CompletedProcess:
    """subprocess.run() equivalent whose timeout kills the WHOLE process tree.
    subprocess.run(timeout=...) kills only the direct child — see
    _kill_process_tree. POSIX gets start_new_session=True so the process group
    is ours to kill. Raises subprocess.TimeoutExpired like subprocess.run."""
    kwargs: dict = dict(
        stdin=subprocess.PIPE, stdout=subprocess.PIPE, stderr=subprocess.PIPE,
        text=True, encoding="utf-8", errors="replace",
    )
    if os.name != "nt":
        kwargs["start_new_session"] = True
    proc = subprocess.Popen(argv, **kwargs)
    try:
        stdout, stderr = proc.communicate(input=prompt, timeout=timeout)
    except subprocess.TimeoutExpired:
        _kill_process_tree(proc)
        try:  # reap so the pipes close and no zombie lingers
            proc.communicate(timeout=10)
        except Exception:
            pass
        raise
    return subprocess.CompletedProcess(argv, proc.returncode, stdout, stderr)


# Why the last gemini_check() failed, for the caller's fail-open banner. The
# (is_clean, reason, ok) contract is fixed by callers/tests, so the detail
# rides alongside it instead of widening the tuple.
LLM_SKIP_REASON = ""


def gemini_check(content: str, tripwires: list[str]) -> tuple[bool, str, bool]:
    """
    Ask Gemini to scan content for PII. Returns (is_clean, reason, ok) where
    ok=False means the layer itself failed (timeout/unparseable/missing binary)
    and the verdict is a fail-open default, not a real CLEAN — callers that
    loop (full_audit) use it to stop burning time on a dead Gemini.
    Fail-open: returns (True, '', False) on any error. On ok=False the module
    global LLM_SKIP_REASON holds the human-readable cause.
    """
    global LLM_SKIP_REASON
    LLM_SKIP_REASON = ""
    argv = resolve_gemini_argv()
    if argv is None:
        LLM_SKIP_REASON = ("no Gemini binary resolvable — GEMINI_CMD unset in env "
                           "and in ~/.pa/secrets.env, and 'gemini' is not on PATH "
                           "(git hooks inherit a minimal environment)")
        print("⚠  PII guard: no Gemini binary (set GEMINI_CMD) — semantic layer OFF", file=sys.stderr)
        return True, "", False
    tripwire_ctx = ""
    if tripwires:
        tripwire_ctx = "\nAlso specifically flag:\n" + "\n".join(f"- {t}" for t in tripwires)

    prompt = f"""You are a security guard for a public open-source git repository.
Analyze the following added lines (git diff) for personal or private information that must NOT appear in a public repository.

Block (respond VIOLATION) if you find:
- Real full names of individuals (first + last) that are not clearly placeholder/example data
- Personal email addresses (not @example.com)
- Financial account numbers, transaction amounts, or specific investment instructions
- Phone numbers, bank account numbers, or card numbers
- Medical or health information
- Real authentication tokens or API keys not already caught by the structural scan{tripwire_ctx}

Do NOT block for:
- Copyright lines like "Copyright (c) YEAR Name" in a LICENSE file
- Generic placeholder data (example@example.com, 12345, TODO, etc.)
- Code variable names that happen to contain common words

Respond with EXACTLY one of these two formats (nothing else):
CLEAN
VIOLATION: <short description>

Added lines to analyze (capped at 400 lines):
{chr(10).join(content.splitlines()[:400])}
"""
    # AI-097: "sturdy, relied-on" means transient failures (timeout, a network
    # blip surfacing as a generic subprocess error) get ONE retry before this
    # layer gives up — a single hiccup silently disabling the semantic scan
    # for an entire push defeats the point of relying on it. A genuinely
    # missing binary is not transient — that fails open immediately, no
    # retry. Explicit encoding="utf-8", errors="replace" is the 2026-07-08
    # crash fix: without it, subprocess.run() on Windows decodes with the
    # system codepage (cp1252), and Gemini's UTF-8 output (emoji, smart
    # quotes) throws inside a background reader thread — an exception that
    # escapes this try/except entirely (wrong thread) and crashes the hook
    # with a raw traceback instead of failing open by design.
    MAX_ATTEMPTS = 2
    last_error: Exception | None = None
    for attempt in range(1, MAX_ATTEMPTS + 1):
        try:
            result = _run_gemini(argv + ["--yolo"], prompt, GEMINI_TIMEOUT)
            response = result.stdout.strip()
            # Find the verdict line (skip any preamble noise)
            for resp_line in response.splitlines():
                resp_line = resp_line.strip()
                if resp_line.startswith("VIOLATION"):
                    return False, resp_line[len("VIOLATION:"):].strip(), True
                if resp_line == "CLEAN":
                    return True, "", True
            # Unparseable — treat like a transient failure and retry once.
            last_error = RuntimeError(f"unparseable response: {response[:200]!r}")
        except FileNotFoundError:
            LLM_SKIP_REASON = f"'{argv[0]}' not found on this machine"
            print(f"⚠  PII guard: '{argv[0]}' not found — skipping LLM check", file=sys.stderr)
            return True, "", False
        except subprocess.TimeoutExpired:
            last_error = TimeoutError(f"gemini call timed out after {GEMINI_TIMEOUT}s")
        except Exception as exc:
            last_error = exc

        if attempt < MAX_ATTEMPTS:
            print(f"⚠  PII guard: Gemini attempt {attempt}/{MAX_ATTEMPTS} failed ({last_error}) — retrying", file=sys.stderr)

    LLM_SKIP_REASON = f"Gemini failed {MAX_ATTEMPTS} consecutive attempts ({last_error})"
    print(f"⚠  PII guard: Gemini failed after {MAX_ATTEMPTS} attempts ({last_error}) — skipping LLM check", file=sys.stderr)
    return True, "", False


# Consecutive infra-failed chunks (each = MAX_ATTEMPTS timeouts) before the
# full audit gives up on the LLM layer for the rest of the run.
LLM_FAILURE_BREAKER = 3

# File extensions that are never worth scanning (binary / generated).
SKIP_EXTENSIONS = (".png", ".jpg", ".jpeg", ".gif", ".ico", ".pdf", ".db", ".sqlite",
                   ".woff", ".woff2", ".ttf", ".zip", ".gz", ".exe", ".dll", ".lock")
FULL_SCAN_MAX_BYTES = 1_000_000  # skip pathological single files


def list_tracked_paths(git_dir: str) -> list[str]:
    """Every tracked path of the repo at git_dir — INCLUDING binaries and
    oversized files that collect_tree skips. Path scanning must see the whole
    name list: `2026_exbank_statement.pdf` is a leak whose content nobody would
    ever scan."""
    result = subprocess.run(
        ["git", "-c", "core.quotepath=false", "--git-dir", git_dir,
         "--work-tree", ".", "ls-files"],
        capture_output=True, text=True, encoding="utf-8", errors="replace",
        timeout=60,
    )
    return [p.strip() for p in result.stdout.splitlines() if p.strip()]


def collect_tree(git_dir: str, paths: list[str] | None = None) -> list[tuple[str, str]]:
    """All tracked (path, content) pairs of the repo at git_dir. Skips binaries."""
    if paths is None:
        paths = list_tracked_paths(git_dir)
    files: list[tuple[str, str]] = []
    for path in paths:
        path = path.strip()
        if not path or path.lower().endswith(SKIP_EXTENSIONS):
            continue
        try:
            if os.path.getsize(path) > FULL_SCAN_MAX_BYTES:
                continue
            with open(path, encoding="utf-8", errors="strict") as f:
                files.append((path, f.read()))
        except (OSError, UnicodeDecodeError):
            continue  # unreadable / binary-ish → skip
    return files


def _token_variants(text: str) -> list[str]:
    """The forms a tripwire must be matched against.

    Identifiers are not prose. `download_exbank_statement.py` has NO word
    boundary before `exbank`, because `_` is a \\w character — so a perfectly
    sensible `\\bEXBANK\\b` tripwire (exactly the anchoring style you want, to
    keep a pattern off ordinary English) silently misses it. That is not a
    hypothetical: it is leak 3, in a filename, and it is also how the same term
    hid inside a commit message that referenced that filename.

    The fix is here rather than in the tripwire file, because the alternative
    is asking a human to hand-maintain a second, looser copy of every pattern —
    and a looser pattern is the thing that produces false positives and gets
    the whole list switched off.

    Two extra views, both cheap:
      * separators (_ - . / \\) -> spaces. LENGTH-PRESERVING, so match offsets
        still map to the right line number.
      * camelCase humps split. Insertion-only, adds no newlines, so line
        numbers still count correctly.
    Splitting can only ADD word boundaries, never merge tokens, so it cannot
    invent a match that the raw text does not contain.
    """
    variants = [text]
    spaced = re.sub(r"[_\-./\\]", " ", text)
    if spaced != text:
        variants.append(spaced)
    camel = re.sub(r"(?<=[a-z0-9])(?=[A-Z])", " ", spaced)
    if camel != spaced:
        variants.append(camel)
    return variants


def scan_path(path: str, tripwires: list[str]) -> list[str]:
    """Tripwire layer against a file NAME. Reported with a `[PATH]` marker so a
    human can tell instantly that the offending string is the filename, not
    something inside it — the distinction that cost a full history rewrite on
    2026-07-21, when download_exbank_statement.py sailed through every
    content-only layer with entirely generic contents.

    Credential patterns are not applied here: they are all shapes that cannot
    occur in a path (a Telegram token contains ':', illegal on Windows), and
    running them would only add false-positive surface."""
    violations: list[str] = []
    variants = _token_variants(path)
    for pattern in tripwires:
        try:
            if any(re.search(pattern, v, re.IGNORECASE) for v in variants):
                violations.append(f"{path} [PATH] tripwire: {pattern}")
        except re.error:
            pass
    return violations


def scan_text(path: str, content: str, tripwires: list[str]) -> list[str]:
    """Regex layers 1+2 against one file. Returns violation descriptions."""
    violations: list[str] = []
    seen: set[str] = set()

    def add(v: str) -> None:
        if v not in seen:
            seen.add(v)
            violations.append(v)

    # Credentials are matched on the RAW text only: a token is a contiguous
    # blob whose own characters include '-' and '_', so normalising separators
    # would break it apart rather than reveal it.
    for pattern in CREDENTIAL_PATTERNS:
        for m in re.finditer(pattern, content):
            line_no = content.count("\n", 0, m.start()) + 1
            add(f"{path}:{line_no} credential pattern: {pattern}")
    variants = _token_variants(content)
    for pattern in tripwires:
        try:
            for variant in variants:
                for m in re.finditer(pattern, variant, re.IGNORECASE):
                    line_no = variant.count("\n", 0, m.start()) + 1
                    add(f"{path}:{line_no} tripwire: {pattern}")
        except re.error:
            pass
    return violations


def full_audit(use_llm: bool) -> int:
    """
    --full mode: scan the ENTIRE tracked tree of the public repo. Unlike the
    per-push diff scan this re-checks pre-existing lines — the gap that let 5
    residual leaks survive until the 2026-06-24 manual audit (AI-094).
    """
    git_dir = os.environ.get("GIT_DIR", ".git-public")
    all_paths = list_tracked_paths(git_dir)
    files = collect_tree(git_dir, all_paths)
    if not files:
        print(f"⚠  PII audit: no tracked files found via git-dir '{git_dir}'", file=sys.stderr)
        return 1

    tripwires = load_tripwires()
    if not tripwires:
        warn_layer_skipped(
            "tripwire regex (personal identifiers), CONTENT and PATH",
            "no patterns loaded from ~/.pa/pii-tripwires.txt",
            stream=sys.stdout,
        )

    violations: list[str] = []
    # Layer 0: PATHS of every tracked file, binaries included.
    for path in all_paths:
        violations.extend(scan_path(path, tripwires))
    path_hits = len(violations)
    # Layers 1+2: contents of every readable tracked file.
    for path, content in files:
        violations.extend(scan_text(path, content, tripwires))
    # Commit messages — a channel a working-tree scan can never see. On
    # 2026-07-21 the public mirror's tip commit SUBJECT still carried the bank
    # filename the commit itself had just removed.
    messages = list_commit_messages(git_dir)
    msg_violations = scan_messages(messages, tripwires)
    violations.extend(msg_violations)

    # Print (and flush) the regex verdict BEFORE the slow LLM phase: if the
    # skill runner kills a long LLM run at its timeout, everything already on
    # stdout is still captured — the regex findings must never die with it.
    print(f"PII audit: scanned {len(all_paths)} tracked paths + contents of "
          f"{len(files)} readable files + {len(messages)} commit messages — "
          f"regex layers: {len(violations)} violation(s) "
          f"({path_hits} in file NAMES, {len(msg_violations)} in COMMIT MESSAGES)",
          flush=True)
    for v in violations:
        print(f"   {v}", flush=True)

    if not use_llm:
        warn_layer_skipped(
            "Gemini semantic scan (layer 3)",
            "--no-llm was passed; regex + tripwire layers only",
            stream=sys.stdout,
        )
    if use_llm:
        # Chunked semantic scan: ~300 lines per Gemini call. Cap sized to fit
        # comfortably inside the pii-audit skill timeout (~40s/call observed).
        # BUT the worst case is 30 chunks x 2 attempts x 120s = 7200s — double
        # the skill's 3600s timeout. When Gemini was degraded, every run hit
        # that wall, was killed by the skill runner (exit 1, no success
        # recorded), and catchup relaunched it hourly for 34 straight hours
        # (2026-07-19/20) — each timed-out chunk also leaking a CPU-spinning
        # orphan. Two guards make the run ALWAYS complete instead: a global
        # LLM time budget, and a consecutive-failure breaker that stops
        # hammering a dead Gemini. Both degrade coverage loudly, exit 0, and
        # let the scheduler record success — partial coverage one week is
        # recoverable; an infinite retry storm is not.
        all_lines = [f"{p}: {ln}" for p, c in files for ln in c.splitlines() if ln.strip()]
        CHUNK, MAX_CHUNKS = 300, 30
        chunks = [all_lines[i:i + CHUNK] for i in range(0, len(all_lines), CHUNK)][:MAX_CHUNKS]
        if len(all_lines) > CHUNK * MAX_CHUNKS:
            print(f"⚠  PII audit: LLM layer sampled {CHUNK * MAX_CHUNKS} of {len(all_lines)} lines", flush=True)
        budget = float(os.environ.get("PA_PII_AUDIT_LLM_BUDGET", "2400"))
        deadline = time.monotonic() + budget
        consecutive_failures = 0
        for i, chunk in enumerate(chunks):
            if time.monotonic() >= deadline:
                warn_layer_skipped(
                    "Gemini semantic scan (layer 3), PARTIAL",
                    f"LLM time budget ({budget:.0f}s, PA_PII_AUDIT_LLM_BUDGET) "
                    f"exhausted after {i}/{len(chunks)} chunks — the remaining "
                    f"{len(chunks) - i} chunks were never semantically scanned",
                    stream=sys.stdout,
                )
                break
            is_clean, reason, ok = gemini_check("\n".join(chunk), tripwires)
            if not ok:
                consecutive_failures += 1
                if consecutive_failures >= LLM_FAILURE_BREAKER:
                    warn_layer_skipped(
                        "Gemini semantic scan (layer 3), PARTIAL",
                        f"Gemini infra-failed {LLM_FAILURE_BREAKER} chunks in a row "
                        f"({LLM_SKIP_REASON or 'unknown cause'}) — breaker tripped at "
                        f"chunk {i + 1}/{len(chunks)}; the rest were never "
                        f"semantically scanned",
                        stream=sys.stdout,
                    )
                    break
                continue
            consecutive_failures = 0
            if not is_clean:
                violations.append(f"(gemini chunk {i + 1}/{len(chunks)}) {reason}")

    # Exit-code contract: 0 = scan COMPLETED (clean or not), non-zero = the scan
    # itself failed. The scheduled pii-audit skill delivers stdout to Telegram
    # only on success — exiting 1 on violations would swallow the violation list
    # behind a generic "skill failed" alert (the exact silent-failure class this
    # audit exists to catch). Findings are the OUTPUT, not an error.
    if violations:
        print(f"🚫 AUDIT RESULT: {len(violations)} VIOLATION(S) — scrub before any public push:", flush=True)
        for v in violations:
            print(f"   {v}", flush=True)
        return 0
    print("✓  clean", flush=True)
    return 0


def main() -> int:
    if "--full" in sys.argv:
        return full_audit(use_llm="--no-llm" not in sys.argv)

    if os.environ.get("PA_SKIP_PII_GUARD"):
        # Deliberate escape hatch (documented for verified-clean force-rewrites)
        # — but it used to vanish without trace, so nobody could later answer
        # "was this ever pushed unchecked?". Loud now, and durably recorded.
        refs = _read_push_refs()
        bar = "!" * 74
        for line in (
            bar,
            "!! PII GUARD BYPASSED — PA_SKIP_PII_GUARD is set",
            "!! NOTHING in this push was scanned: no credential regex, no",
            "!! tripwires, no path check, no semantic scan.",
            *(f"!!   ref: {r}" for r in refs),
            bar,
        ):
            print(line, file=sys.stderr)
        log_path = record_bypass(refs)
        if log_path:
            print(f"   bypass recorded to {log_path}", file=sys.stderr)
        return 0

    collect_diff()
    if not ADDED and not TOUCHED_PATHS and not MESSAGES:
        return 0

    added_content = "\n".join(ADDED)
    tripwires = load_tripwires()
    if not tripwires:
        warn_layer_skipped(
            "tripwire regex (personal identifiers), CONTENT and PATH",
            "no patterns loaded from ~/.pa/pii-tripwires.txt",
        )

    violations: list[str] = []

    # Layer 0: PATHS the push ships. The name is data too.
    for path in TOUCHED_PATHS:
        violations.extend(scan_path(path, tripwires))

    # Layers 1+2 over the FULL resulting content of every touched file — not
    # just the '+' lines. Pre-existing PII in a file this push touches is the
    # single largest blind spot the added-lines-only scan ever had.
    for path, content in TOUCHED_FILES:
        violations.extend(scan_text(path, content, tripwires))

    # Layers 1+2 over the added lines as well. Cheap, catches the common case,
    # and it is the ONLY coverage for files whose blob could not be read.
    if added_content:
        violations.extend(scan_text("(added lines)", added_content, tripwires))

    # Layers 1+2 over the commit messages the push publishes.
    violations.extend(scan_messages(MESSAGES, tripwires))

    violations = list(dict.fromkeys(violations))  # stable dedupe

    print(f"ℹ  PII guard scope: {len(TOUCHED_PATHS)} path(s), full content of "
          f"{len(TOUCHED_FILES)} file(s), {len(ADDED)} added line(s), "
          f"{len(MESSAGES)} commit message(s). "
          f"Gemini layer sees ADDED LINES ONLY (budget) — whole-tree semantic "
          f"coverage comes from the weekly --full audit.", file=sys.stderr)
    if UNREADABLE_PATHS:
        print(f"ℹ  PII guard: {len(UNREADABLE_PATHS)} touched path(s) were not "
              f"content-scanned (binary/oversized/unreadable): "
              f"{', '.join(UNREADABLE_PATHS[:5])}"
              f"{' …' if len(UNREADABLE_PATHS) > 5 else ''}", file=sys.stderr)

    if violations:
        print("🚫 PII guard: personal data detected — push aborted", file=sys.stderr)
        for v in violations:
            print(f"   {v}", file=sys.stderr)
        return 1

    # Layer 3: Gemini semantic scan of the ADDED LINES (ok=False → fail-open).
    if added_content:
        is_clean, reason, ok = gemini_check(added_content, tripwires)
        if not ok:
            warn_layer_skipped(
                "Gemini semantic scan (layer 3)",
                LLM_SKIP_REASON or "unknown cause",
            )
        if not is_clean:
            print("🚫 PII guard (Gemini): personal data detected — push aborted", file=sys.stderr)
            print(f"   Reason: {reason}", file=sys.stderr)
            return 1

    print("✓  PII guard: clean", file=sys.stderr)
    return 0


if __name__ == "__main__":
    sys.exit(main())
